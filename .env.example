# ============================================================
# TFG Records - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
# Run: docker compose up -d

# --- Database ---
POSTGRES_DB=records_db
POSTGRES_USER=records_user
POSTGRES_PASSWORD=VMydRDAI8yXAkFvsxB8XFwW3

# --- Backend ---
SPRING_PROFILES_ACTIVE=prod
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false

# --- JWT ---
# Base64-encoded secret (min 32 bytes recommended)
JWT_SECRET=fP4iY1uH3hhA/9Mjf2wDAIcrlAfFM8uW+rvXMtSu65Bh10CC1HTIsM10IfY+s2VM28XrnBO/7oJtpw6GaIJsOw==
JWT_EXPIRATION_MS=900000

# --- Flowable BPM ---
FLOWABLE_ASYNC_EXECUTOR_ACTIVATE=true

# --- Management & Monitoring ---
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4300

# --- Logging ---
LOG_LEVEL=INFO

# --- Mailing (SMTP + Mailpit) ---
MAILING_ENABLED=true
MAILING_QUEUE_ENABLED=false
MAILING_FROM_EMAIL=no-reply@records.local
MAILING_FROM_NAME=Records
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAILING_VERIFICATION_BASE_URL=http://localhost:4200/sede/verificar-email

# --- Storage ---
STORAGE_DOCUMENTS_PATH=./data/documents

# --- LibreOffice (PDF/A conversion) ---
# LIBREOFFICE_HOME=/usr/lib/libreoffice
# LIBREOFFICE_PORT=2002
